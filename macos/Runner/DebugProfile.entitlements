<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox is intentionally DISABLED in Debug profile so
	     ad-hoc-signed `flutter run` builds can write to the macOS
	     Keychain without a development certificate. The Release
	     entitlements re-enable sandbox + keychain-access-groups for
	     production builds. See docs/auth-model.md. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
